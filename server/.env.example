# 服务监听地址
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# 管理端 JWT 签名密钥（生产环境务必更换）
JWT_SECRET=change-me-in-production

# 数据库（PostgreSQL）
# 先执行：psql -U postgres -d push_hub -f sql/schema.sql
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/push_hub

# 在线推送默认参数（新建应用的默认值，可在控制台按应用覆盖）
ONLINE_PUSH_FALLBACK_SECS=90
ONLINE_MESSAGE_CACHE_SECS=86400

# 说明：首次启动不会自动创建管理员或默认应用。
# 打开管理端后按引导创建管理员账号，登录后再创建应用。
